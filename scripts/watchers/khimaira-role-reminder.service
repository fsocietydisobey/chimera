[Unit]
Description=khimaira — periodic role-budget directive broadcast (Phase B v1.7.3)
Documentation=https://github.com/fsocietydisobey/khimaira

[Service]
Type=oneshot
ExecStart=%h/.local/bin/khimaira-role-reminder-broadcast.sh
StandardOutput=append:%h/.local/state/khimaira/role-reminder.log
StandardError=append:%h/.local/state/khimaira/role-reminder.log
